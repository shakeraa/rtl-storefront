// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String    @default("")
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@index([shop])
  @@index([expires])
}

model TranslationCache {
  id             String   @id @default(cuid())
  cacheKey       String   @unique
  provider       String
  sourceLocale   String
  targetLocale   String
  sourceText     String
  translatedText String
  context        String?
  shop           String   @default("")
  hits           Int      @default(0)
  lastUsedAt     DateTime @default(now())
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([sourceLocale, targetLocale])
  @@index([expiresAt])
  @@index([shop])
}

model TranslationMemory {
  id             String   @id @default(cuid())
  shop           String
  sourceLocale   String
  targetLocale   String
  sourceText     String
  translatedText String
  context        String?
  category       String?
  quality        Int      @default(100)
  usageCount     Int      @default(0)
  lastUsedAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([shop, sourceLocale, targetLocale])
  @@index([shop, sourceText])
  @@unique([shop, sourceLocale, targetLocale, sourceText])
}

model GlossaryEntry {
  id             String   @id @default(cuid())
  shop           String
  sourceLocale   String
  targetLocale   String
  sourceTerm     String
  translatedTerm String
  neverTranslate Boolean  @default(false)
  caseSensitive  Boolean  @default(false)
  category       String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([shop, sourceLocale, targetLocale, sourceTerm])
  @@index([shop, sourceLocale])
}

model CulturalContext {
  id             String   @id @default(cuid())
  shop           String
  locale         String
  category       String
  dialect        String?
  formalityLevel String   @default("formal")
  culturalNotes  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([shop, locale, category])
  @@index([shop, locale])
}

model ConsentRecord {
  id          String   @id @default(cuid())
  shop        String
  purpose     String
  granted     Boolean  @default(false)
  grantedAt   DateTime?
  revokedAt   DateTime?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shop, purpose])
  @@index([shop])
}

model DataAccessLog {
  id          String   @id @default(cuid())
  shop        String
  action      String
  dataType    String
  performedBy String?
  details     String?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([shop, createdAt])
  @@index([action])
}

model DataRetentionPolicy {
  id              String   @id @default(cuid())
  shop            String
  dataType        String
  retentionDays   Int      @default(365)
  autoDelete      Boolean  @default(false)
  lastCleanup     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([shop, dataType])
}

model BillingPlan {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  priceInCents     Int
  trialDays        Int      @default(14)
  maxLanguages     Int
  maxWordsPerMonth Int
  features         String   @default("[]")
  sortOrder        Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  subscriptions ShopSubscription[]
}

model ShopSubscription {
  id                 String    @id @default(cuid())
  shop               String    @unique
  planId             String?
  plan               BillingPlan? @relation(fields: [planId], references: [id])
  status             String    @default("trial")
  shopifyChargeId    String?   @unique
  trialStartedAt     DateTime?
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([status])
  @@index([planId])
}

model ShopUsage {
  id          String   @id @default(cuid())
  shop        String
  periodStart DateTime
  wordsUsed   Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([shop, periodStart])
  @@index([shop])
}

model TranslationUsage {
  id              String   @id @default(cuid())
  shop            String
  
  // Provider details
  provider        String   // openai, deepl, google, azure, etc.
  model           String?  // specific model used (gpt-4, gpt-3.5-turbo, etc.)
  
  // Usage metrics
  characters      Int      // characters translated
  words           Int      // estimated word count
  apiCalls        Int      @default(1) // usually 1 per translation
  
  // Cost tracking (in cents for precision)
  costCents       Int      @default(0)
  costPer1kChars  Float    // rate at time of translation
  
  // Performance
  responseTimeMs  Int?     // API response time in milliseconds
  
  // Context
  sourceLocale    String
  targetLocale    String
  resourceType    String?  // product, collection, page, blog, etc.
  resourceId      String?  // Shopify resource ID
  contentType     String?  // title, description, meta, etc.
  
  // Quality/Success
  success         Boolean  @default(true)
  errorMessage    String?
  qualityScore    Int?     // 0-100 if available
  
  // Metadata
  cached          Boolean  @default(false) // was this served from cache?
  glossaryUsed    Boolean  @default(false)
  
  createdAt       DateTime @default(now())
  
  @@index([shop, createdAt])
  @@index([shop, provider])
  @@index([shop, resourceType])
  @@index([createdAt])
}

model TranslationAlert {
  id              String    @id @default(cuid())
  shop            String
  category        String    // untranslated, new_content, coverage_drop, quality, etc.
  severity        String    // critical, warning, info
  title           String
  message         String
  locale          String
  resourceType    String?   // product, collection, page, etc.
  resourceId      String?   // Shopify resource ID
  count           Int?      // number of items (for untranslated count)
  dismissed       Boolean   @default(false)
  dismissedAt     DateTime?
  dismissedBy     String?
  createdAt       DateTime  @default(now())
  
  @@index([shop, dismissed])
  @@index([shop, severity])
  @@index([shop, createdAt])
  @@index([dismissed, createdAt])
}

model NotificationPreference {
  id                String   @id @default(cuid())
  shop              String
  templateType      String   // translation_complete, review_needed, error, weekly_digest
  emailEnabled      Boolean  @default(true)
  inAppEnabled      Boolean  @default(true)
  updatedAt         DateTime @updatedAt
  
  @@unique([shop, templateType])
  @@index([shop])
}

model AlertConfiguration {
  id                    String   @id @default(cuid())
  shop                  String   @unique
  enableInApp           Boolean  @default(true)
  enableEmail           Boolean  @default(false)
  emailDigestFrequency  String   @default("weekly") // daily, weekly, never
  emailRecipients       String   @default("[]")     // JSON array of emails
  
  // Thresholds
  untranslatedCritical  Int      @default(50)
  untranslatedWarning   Int      @default(10)
  coverageDropPercent   Int      @default(5)
  staleTranslationDays  Int      @default(90)
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ShopSettings {
  id                  String   @id @default(cuid())
  shop                String   @unique
  aiProvider          String   @default("openai")
  openaiApiKey        String?
  deeplApiKey         String?
  googleAccessToken   String?
  googleProjectId     String?
  azureTranslatorKey  String?
  azureTranslatorRegion String?
  awsAccessKeyId      String?
  awsSecretAccessKey  String?
  awsRegion           String?
  anthropicApiKey     String?
  libreTranslateUrl   String?
  libreTranslateApiKey String?
  sourceLocale        String   @default("en")
  targetLocales       String   @default("[\"ar\",\"he\"]")
  autoDetectRTL       Boolean  @default(true)
  arabicFont          String   @default("noto-sans-arabic")
  hebrewFont          String   @default("heebo")
  farsiFont           String   @default("vazirmatn")
  enableTM            Boolean  @default(true)
  fuzzyThreshold      Int      @default(80)
  autoSuggest         Boolean  @default(true)
  qualityReview       Boolean  @default(false)
  confidenceThreshold Int      @default(70)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model TeamInvite {
  id          String    @id @default(cuid())
  shop        String
  email       String
  role        String
  token       String    @unique
  status      String    @default("pending") // pending, sent, accepted, expired, revoked
  invitedBy   String    // user who sent the invite
  invitedAt   DateTime  @default(now())
  expiresAt   DateTime
  sentAt      DateTime?
  acceptedAt  DateTime?
  revokedAt   DateTime?
  resentAt    DateTime? // last time resent
  resentCount Int       @default(0)
  emailError  String?   // error message if email failed
  
  @@unique([shop, email])
  @@index([shop, status])
  @@index([token])
}

model TeamMember {
  id          String   @id @default(cuid())
  shop        String
  userId      String   @unique // Shopify user ID or custom ID
  email       String
  name        String?
  role        String   // admin, manager, translator, viewer
  invitedBy   String
  invitedAt   DateTime @default(now())
  acceptedAt  DateTime?
  status      String   @default("active") // active, inactive, suspended
  apiKey      String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([shop, email])
  @@index([shop, status])
}
