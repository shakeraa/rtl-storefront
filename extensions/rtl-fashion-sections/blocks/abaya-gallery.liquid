{% comment %}
  Abaya Product Gallery - RTL Optimized
  T0006: RTL-First Fashion Design
{% endcomment %}

<section class="abaya-gallery" data-section-id="{{ section.id }}" dir="{{ section.settings.text_direction }}">
  <div class="abaya-gallery__container">
    {% if section.settings.title != blank %}
      <h2 class="abaya-gallery__title">{{ section.settings.title }}</h2>
    {% endif %}
    
    {% if section.settings.description != blank %}
      <p class="abaya-gallery__description">{{ section.settings.description }}</p>
    {% endif %}
    
    <div class="abaya-gallery__grid" data-columns="{{ section.settings.columns }}">
      {% for block in section.blocks %}
        <div class="abaya-gallery__item" {{ block.shopify_attributes }}>
          <div class="abaya-card">
            <div class="abaya-card__image-wrapper">
              {% if block.settings.product.featured_image != blank %}
                <img
                  src="{{ block.settings.product.featured_image | image_url: width: 600 }}"
                  alt="{{ block.settings.product.title | escape }}"
                  class="abaya-card__image"
                  loading="lazy"
                  width="600"
                  height="800"
                >
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'abaya-card__placeholder' }}
              {% endif %}
              
              {% if block.settings.show_badge and block.settings.badge_text != blank %}
                <span class="abaya-card__badge">{{ block.settings.badge_text }}</span>
              {% endif %}
            </div>
            
            <div class="abaya-card__content">
              <h3 class="abaya-card__title">
                {{ block.settings.product.title | default: block.settings.custom_title }}
              </h3>
              
              {% if block.settings.show_price %}
                <p class="abaya-card__price">
                  {% if block.settings.product.compare_at_price > block.settings.product.price %}
                    <span class="abaya-card__price--sale">
                      {{ block.settings.product.price | money }}
                    </span>
                    <s class="abaya-card__price--compare">
                      {{ block.settings.product.compare_at_price | money }}
                    </s>
                  {% else %}
                    {{ block.settings.product.price | money }}
                  {% endif %}
                </p>
              {% endif %}
              
              {% if block.settings.show_size_guide %}
                <button class="abaya-card__size-guide" data-product-id="{{ block.settings.product.id }}">
                  {{ section.settings.size_guide_text }}
                </button>
              {% endif %}
              
              <a href="{{ block.settings.product.url | default: '#' }}" class="abaya-card__link">
                {{ section.settings.view_text }}
              </a>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .abaya-gallery {
    padding: 4rem 2rem;
    background: {{ section.settings.background_color }};
  }
  
  .abaya-gallery__container {
    max-width: 1400px;
    margin: 0 auto;
  }
  
  .abaya-gallery__title {
    text-align: center;
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: {{ section.settings.heading_color }};
  }
  
  [dir="rtl"] .abaya-gallery__title {
    font-family: 'Noto Sans Arabic', sans-serif;
  }
  
  .abaya-gallery__description {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 3rem;
    color: {{ section.settings.text_color }};
  }
  
  .abaya-gallery__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: 2rem;
  }
  
  @media (max-width: 992px) {
    .abaya-gallery__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 576px) {
    .abaya-gallery__grid {
      grid-template-columns: 1fr;
    }
  }
  
  .abaya-card {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    transition: transform 0.3s, box-shadow 0.3s;
  }
  
  .abaya-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
  }
  
  .abaya-card__image-wrapper {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: #f5f5f5;
  }
  
  .abaya-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s;
  }
  
  .abaya-card:hover .abaya-card__image {
    transform: scale(1.05);
  }
  
  .abaya-card__placeholder {
    width: 100%;
    height: 100%;
    background: #e5e5e5;
  }
  
  .abaya-card__badge {
    position: absolute;
    top: 1rem;
    {{ section.settings.text_direction | replace: 'ltr', 'right' | replace: 'rtl', 'left' }}: 1rem;
    background: {{ section.settings.badge_color }};
    color: #fff;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: 600;
  }
  
  .abaya-card__content {
    padding: 1.5rem;
    text-align: {{ section.settings.text_direction | replace: 'ltr', 'left' | replace: 'rtl', 'right' }};
  }
  
  [dir="rtl"] .abaya-card__content {
    font-family: 'Noto Sans Arabic', sans-serif;
  }
  
  .abaya-card__title {
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
    color: {{ section.settings.heading_color }};
  }
  
  .abaya-card__price {
    font-size: 1.25rem;
    font-weight: 600;
    color: {{ section.settings.price_color }};
    margin-bottom: 1rem;
  }
  
  .abaya-card__price--sale {
    color: #e74c3c;
  }
  
  .abaya-card__price--compare {
    margin-{{ section.settings.text_direction | replace: 'ltr', 'left' | replace: 'rtl', 'right' }}: 0.5rem;
    opacity: 0.6;
    font-size: 1rem;
  }
  
  .abaya-card__size-guide {
    display: block;
    width: 100%;
    padding: 0.75rem;
    margin-bottom: 0.75rem;
    background: transparent;
    border: 1px solid {{ section.settings.button_color }};
    color: {{ section.settings.button_color }};
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  
  .abaya-card__size-guide:hover {
    background: {{ section.settings.button_color }};
    color: #fff;
  }
  
  .abaya-card__link {
    display: block;
    text-align: center;
    padding: 0.75rem;
    background: {{ section.settings.button_color }};
    color: {{ section.settings.button_text_color }};
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: opacity 0.2s;
  }
  
  .abaya-card__link:hover {
    opacity: 0.9;
  }
</style>

{% schema %}
{
  "name": "Abaya Gallery",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Our Abaya Collection"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover elegant abayas for every occasion"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "text_direction",
      "label": "Text Direction",
      "options": [
        { "value": "ltr", "label": "Left to Right" },
        { "value": "rtl", "label": "Right to Left" }
      ],
      "default": "rtl"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price Color",
      "default": "#1a5f2a"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Color",
      "default": "#1a5f2a"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Badge Color",
      "default": "#e74c3c"
    },
    {
      "type": "text",
      "id": "size_guide_text",
      "label": "Size Guide Button Text",
      "default": "Size Guide"
    },
    {
      "type": "text",
      "id": "view_text",
      "label": "View Button Text",
      "default": "View Details"
    }
  ],
  "target": "section"
}
{% endschema %}