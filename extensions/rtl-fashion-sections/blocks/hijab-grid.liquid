{% comment %}
  Hijab Product Grid - RTL Optimized
  T0006: RTL-First Fashion Design
{% endcomment %}

<section class="hijab-grid" data-section-id="{{ section.id }}" dir="{{ section.settings.text_direction }}">
  <div class="hijab-grid__container">
    {% if section.settings.title != blank %}
      <div class="hijab-grid__header">
        <h2 class="hijab-grid__title">{{ section.settings.title }}</h2>
        {% if section.settings.subtitle != blank %}
          <p class="hijab-grid__subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if section.settings.show_filter_tabs %}
      <div class="hijab-grid__filters" role="tablist">
        {% assign filter_labels = section.settings.filter_labels | split: ',' %}
        {% for label in filter_labels %}
          <button
            class="hijab-grid__filter-tab {% if forloop.first %}hijab-grid__filter-tab--active{% endif %}"
            role="tab"
            data-filter="{{ label | strip | handleize }}"
          >
            {{ label | strip }}
          </button>
        {% endfor %}
      </div>
    {% endif %}

    <div
      class="hijab-grid__products"
      data-columns="{{ section.settings.columns }}"
      style="--grid-columns: {{ section.settings.columns }};"
    >
      {% for block in section.blocks %}
        <div
          class="hijab-card"
          data-category="{{ block.settings.category | handleize }}"
          {{ block.shopify_attributes }}
        >
          <div class="hijab-card__image-wrapper">
            {% if block.settings.product.featured_image != blank %}
              <img
                src="{{ block.settings.product.featured_image | image_url: width: 500 }}"
                alt="{{ block.settings.product.title | escape }}"
                class="hijab-card__image"
                loading="lazy"
                width="500"
                height="500"
              >
            {% else %}
              {{ 'product-apparel-2' | placeholder_svg_tag: 'hijab-card__placeholder' }}
            {% endif %}

            {% if block.settings.product.available == false %}
              <span class="hijab-card__badge hijab-card__badge--sold-out">
                {{ section.settings.sold_out_text | default: 'Sold Out' }}
              </span>
            {% elsif block.settings.product.compare_at_price > block.settings.product.price %}
              <span class="hijab-card__badge hijab-card__badge--sale">
                {% assign discount = block.settings.product.compare_at_price | minus: block.settings.product.price | times: 100 | divided_by: block.settings.product.compare_at_price %}
                -{{ discount }}%
              </span>
            {% elsif block.settings.is_new %}
              <span class="hijab-card__badge hijab-card__badge--new">
                {{ section.settings.new_text | default: 'New' }}
              </span>
            {% endif %}

            {% if section.settings.show_quick_add %}
              <button
                class="hijab-card__quick-add"
                data-product-id="{{ block.settings.product.id }}"
                data-variant-id="{{ block.settings.product.first_available_variant.id }}"
                aria-label="{{ section.settings.add_to_cart_text }}: {{ block.settings.product.title | escape }}"
              >
                {{ section.settings.add_to_cart_text | default: 'Add to Cart' }}
              </button>
            {% endif %}
          </div>

          <div class="hijab-card__body">
            {% if block.settings.show_color_swatches and block.settings.product.variants.size > 1 %}
              <div class="hijab-card__swatches" aria-label="{{ 'Color options' }}">
                {% for variant in block.settings.product.variants limit: 6 %}
                  <button
                    class="hijab-card__swatch"
                    style="background-color: {{ variant.title | downcase | replace: ' ', '' }};"
                    title="{{ variant.title }}"
                    data-variant-id="{{ variant.id }}"
                  ></button>
                {% endfor %}
              </div>
            {% endif %}

            <h3 class="hijab-card__title">
              <a href="{{ block.settings.product.url | default: '#' }}" class="hijab-card__title-link">
                {{ block.settings.product.title | default: block.settings.custom_title }}
              </a>
            </h3>

            {% if section.settings.show_price %}
              <div class="hijab-card__price-wrapper">
                {% if block.settings.product.compare_at_price > block.settings.product.price %}
                  <span class="hijab-card__price hijab-card__price--sale">
                    {{ block.settings.product.price | money }}
                  </span>
                  <s class="hijab-card__price hijab-card__price--compare">
                    {{ block.settings.product.compare_at_price | money }}
                  </s>
                {% else %}
                  <span class="hijab-card__price">
                    {{ block.settings.product.price | money }}
                  </span>
                {% endif %}
              </div>
            {% endif %}

            {% if section.settings.show_material and block.settings.material != blank %}
              <p class="hijab-card__material">{{ block.settings.material }}</p>
            {% endif %}
          </div>
        </div>
      {% else %}
        {% for i in (1..section.settings.columns) %}
          <div class="hijab-card hijab-card--placeholder">
            <div class="hijab-card__image-wrapper">
              {{ 'product-apparel-2' | placeholder_svg_tag: 'hijab-card__placeholder' }}
            </div>
            <div class="hijab-card__body">
              <h3 class="hijab-card__title">{{ 'حجاب' | append: ' ' | append: forloop.index }}</h3>
              <span class="hijab-card__price">--</span>
            </div>
          </div>
        {% endfor %}
      {% endfor %}
    </div>

    {% if section.settings.show_view_all and section.settings.view_all_link != blank %}
      <div class="hijab-grid__footer">
        <a href="{{ section.settings.view_all_link }}" class="hijab-grid__view-all">
          {{ section.settings.view_all_text | default: 'View All' }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .hijab-grid {
    padding: 3rem 1.5rem;
    background: {{ section.settings.background_color }};
  }

  .hijab-grid__container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .hijab-grid__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  [dir="rtl"] .hijab-grid__header {
    font-family: 'Noto Sans Arabic', 'Segoe UI', sans-serif;
  }

  .hijab-grid__title {
    font-size: 2rem;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin-bottom: 0.5rem;
  }

  .hijab-grid__subtitle {
    font-size: 1rem;
    color: {{ section.settings.text_color }};
    opacity: 0.8;
  }

  /* Filter tabs */
  .hijab-grid__filters {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  [dir="rtl"] .hijab-grid__filters {
    flex-direction: row-reverse;
  }

  .hijab-grid__filter-tab {
    padding: 0.5rem 1.25rem;
    border: 2px solid {{ section.settings.accent_color }};
    background: transparent;
    color: {{ section.settings.accent_color }};
    border-radius: 2rem;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 600;
    transition: background 0.2s, color 0.2s;
  }

  .hijab-grid__filter-tab--active,
  .hijab-grid__filter-tab:hover {
    background: {{ section.settings.accent_color }};
    color: #fff;
  }

  /* Product grid — RTL-aware via logical properties */
  .hijab-grid__products {
    display: grid;
    grid-template-columns: repeat(var(--grid-columns, 4), 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 1024px) {
    .hijab-grid__products {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hijab-grid__products {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
  }

  @media (max-width: 400px) {
    .hijab-grid__products {
      grid-template-columns: 1fr;
    }
  }

  /* Card */
  .hijab-card {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.08);
    transition: transform 0.25s, box-shadow 0.25s;
  }

  .hijab-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.12);
  }

  .hijab-card__image-wrapper {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f7f7f7;
  }

  .hijab-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }

  .hijab-card:hover .hijab-card__image {
    transform: scale(1.06);
  }

  .hijab-card__placeholder {
    width: 100%;
    height: 100%;
    opacity: 0.4;
  }

  /* Badges */
  .hijab-card__badge {
    position: absolute;
    top: 0.75rem;
    inset-inline-start: 0.75rem;
    padding: 0.25rem 0.625rem;
    border-radius: 3px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .hijab-card__badge--sale {
    background: #e74c3c;
    color: #fff;
  }

  .hijab-card__badge--new {
    background: {{ section.settings.accent_color }};
    color: #fff;
  }

  .hijab-card__badge--sold-out {
    background: #999;
    color: #fff;
  }

  /* Quick add */
  .hijab-card__quick-add {
    position: absolute;
    bottom: 0;
    inset-inline-start: 0;
    inset-inline-end: 0;
    padding: 0.75rem;
    background: rgba(0, 0, 0, 0.75);
    color: #fff;
    border: none;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.875rem;
    opacity: 0;
    transform: translateY(100%);
    transition: opacity 0.25s, transform 0.25s;
  }

  .hijab-card:hover .hijab-card__quick-add {
    opacity: 1;
    transform: translateY(0);
  }

  /* Card body */
  .hijab-card__body {
    padding: 1rem;
    text-align: start;
  }

  [dir="rtl"] .hijab-card__body {
    font-family: 'Noto Sans Arabic', 'Segoe UI', sans-serif;
  }

  /* Color swatches */
  .hijab-card__swatches {
    display: flex;
    gap: 0.375rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  [dir="rtl"] .hijab-card__swatches {
    flex-direction: row-reverse;
  }

  .hijab-card__swatch {
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 50%;
    border: 2px solid rgba(0,0,0,0.15);
    cursor: pointer;
    transition: transform 0.15s;
  }

  .hijab-card__swatch:hover {
    transform: scale(1.2);
  }

  .hijab-card__title {
    font-size: 0.9375rem;
    font-weight: 600;
    margin-bottom: 0.375rem;
    color: {{ section.settings.heading_color }};
    line-height: 1.3;
  }

  .hijab-card__title-link {
    color: inherit;
    text-decoration: none;
  }

  .hijab-card__title-link:hover {
    text-decoration: underline;
  }

  .hijab-card__price-wrapper {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  [dir="rtl"] .hijab-card__price-wrapper {
    flex-direction: row-reverse;
  }

  .hijab-card__price {
    font-size: 1rem;
    font-weight: 700;
    color: {{ section.settings.price_color }};
  }

  .hijab-card__price--sale {
    color: #e74c3c;
  }

  .hijab-card__price--compare {
    font-size: 0.875rem;
    font-weight: 400;
    opacity: 0.55;
    color: {{ section.settings.text_color }};
  }

  .hijab-card__material {
    font-size: 0.8125rem;
    color: {{ section.settings.text_color }};
    opacity: 0.7;
    margin-top: 0.25rem;
  }

  /* Footer */
  .hijab-grid__footer {
    text-align: center;
    margin-top: 2.5rem;
  }

  .hijab-grid__view-all {
    display: inline-block;
    padding: 0.875rem 2.5rem;
    border: 2px solid {{ section.settings.accent_color }};
    color: {{ section.settings.accent_color }};
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: background 0.2s, color 0.2s;
  }

  .hijab-grid__view-all:hover {
    background: {{ section.settings.accent_color }};
    color: #fff;
  }
</style>

{% schema %}
{
  "name": "Hijab Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "تشكيلة الحجاب"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Elegant hijabs for every style"
    },
    {
      "type": "select",
      "id": "text_direction",
      "label": "Text Direction",
      "options": [
        { "value": "ltr", "label": "Left to Right" },
        { "value": "rtl", "label": "Right to Left" }
      ],
      "default": "rtl"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show Price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "Show Quick Add Button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_material",
      "label": "Show Material Label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_filter_tabs",
      "label": "Show Filter Tabs",
      "default": false
    },
    {
      "type": "text",
      "id": "filter_labels",
      "label": "Filter Tab Labels (comma-separated)",
      "default": "All, Cotton, Chiffon, Silk, Jersey"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show View All Button",
      "default": true
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All Link"
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View All Button Text",
      "default": "View All Hijabs"
    },
    {
      "type": "text",
      "id": "add_to_cart_text",
      "label": "Add to Cart Text",
      "default": "Add to Cart"
    },
    {
      "type": "text",
      "id": "sold_out_text",
      "label": "Sold Out Text",
      "default": "Sold Out"
    },
    {
      "type": "text",
      "id": "new_text",
      "label": "New Badge Text",
      "default": "New"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#fafafa"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price Color",
      "default": "#1a5f2a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#1a5f2a"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom Title (overrides product title)"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category Tag (for filtering)",
          "default": "all"
        },
        {
          "type": "text",
          "id": "material",
          "label": "Material Label",
          "info": "e.g. 100% Cotton, Premium Chiffon"
        },
        {
          "type": "checkbox",
          "id": "show_color_swatches",
          "label": "Show Color Swatches",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "is_new",
          "label": "Mark as New",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hijab Grid",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
