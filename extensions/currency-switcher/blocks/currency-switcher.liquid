{% comment %}
  Currency Switcher Block
  Renders a dropdown that lets customers select their preferred display currency.
  Persists the selection in a cookie and reloads the page so theme price rendering
  (Shopify Markets / custom storefront) picks up the new currency.
{% endcomment %}

{{ 'currency-switcher.css' | asset_url | stylesheet_tag }}

<div
  class="rtl-currency-switcher"
  data-position="{{ block.settings.position }}"
  data-show-symbol="{{ block.settings.show_symbol }}"
  {{ block.shopify_attributes }}
>
  <button
    class="rtl-currency-switcher__trigger"
    aria-expanded="false"
    aria-haspopup="listbox"
    aria-label="{{ 'currency_switcher.select_currency' | t: default: 'Select currency' }}"
  >
    <span class="rtl-currency-switcher__icon" aria-hidden="true">
      {% if block.settings.show_icon %}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
          <path d="M8 3v10M5 5.5c0-1.4 1.3-2.5 3-2.5s3 1.1 3 2.5c0 2.5-6 2.5-6 5 0 1.4 1.3 2.5 3 2.5s3-1.1 3-2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      {% endif %}
    </span>
    <span class="rtl-currency-switcher__current">
      {%- assign current_currency = cart.currency.iso_code -%}
      {% if block.settings.show_symbol %}
        {{ current_currency }}
      {% else %}
        {{ current_currency }}
      {% endif %}
    </span>
    <svg class="rtl-currency-switcher__caret" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
      <path d="M2 4l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <ul class="rtl-currency-switcher__list" role="listbox" hidden aria-label="{{ 'currency_switcher.available_currencies' | t: default: 'Available currencies' }}">
    {% for currency in shop.enabled_currencies %}
      <li
        class="rtl-currency-switcher__option"
        role="option"
        data-currency="{{ currency.iso_code }}"
        {% if currency.iso_code == cart.currency.iso_code %}aria-selected="true"{% else %}aria-selected="false"{% endif %}
      >
        <button
          type="button"
          class="rtl-currency-switcher__option-btn{% if currency.iso_code == cart.currency.iso_code %} rtl-currency-switcher__option-btn--active{% endif %}"
          data-currency="{{ currency.iso_code }}"
        >
          <span class="rtl-currency-switcher__option-code">{{ currency.iso_code }}</span>
          {% if block.settings.show_currency_name %}
            <span class="rtl-currency-switcher__option-name">{{ currency.name }}</span>
          {% endif %}
          {% if block.settings.show_symbol %}
            <span class="rtl-currency-switcher__option-symbol">{{ currency.symbol }}</span>
          {% endif %}
        </button>
      </li>
    {% endfor %}
  </ul>
</div>

<script>
(function () {
  'use strict';

  var COOKIE_NAME = 'rtl_currency';
  var COOKIE_DAYS = 30;

  function setCookie(name, value, days) {
    var expires = '';
    if (days) {
      var date = new Date();
      date.setTime(date.getTime() + days * 24 * 60 * 60 * 1000);
      expires = '; expires=' + date.toUTCString();
    }
    document.cookie = name + '=' + encodeURIComponent(value) + expires + '; path=/; SameSite=Lax';
  }

  function initSwitcher(switcher) {
    var trigger = switcher.querySelector('.rtl-currency-switcher__trigger');
    var list = switcher.querySelector('.rtl-currency-switcher__list');

    if (!trigger || !list) return;

    function openList() {
      trigger.setAttribute('aria-expanded', 'true');
      list.hidden = false;
      // Focus the active option
      var active = list.querySelector('[aria-selected="true"] .rtl-currency-switcher__option-btn');
      if (active) active.focus();
    }

    function closeList() {
      trigger.setAttribute('aria-expanded', 'false');
      list.hidden = true;
    }

    function toggleList() {
      if (list.hidden) {
        openList();
      } else {
        closeList();
      }
    }

    trigger.addEventListener('click', function (e) {
      e.stopPropagation();
      toggleList();
    });

    trigger.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        toggleList();
      } else if (e.key === 'Escape') {
        closeList();
        trigger.focus();
      }
    });

    // Handle currency selection
    list.addEventListener('click', function (e) {
      var btn = e.target.closest('.rtl-currency-switcher__option-btn');
      if (!btn) return;

      var currency = btn.getAttribute('data-currency');
      if (!currency) return;

      setCookie(COOKIE_NAME, currency, COOKIE_DAYS);

      // Use Shopify's built-in currency update if available (Shopify Markets),
      // otherwise fall back to a simple page reload which lets the theme pick
      // up the cookie value.
      if (window.Shopify && typeof window.Shopify.updateCurrency === 'function') {
        window.Shopify.updateCurrency(currency);
      } else {
        // POST to Shopify currency endpoint (classic themes)
        var form = document.createElement('form');
        form.method = 'post';
        form.action = '/cart/update';
        form.style.display = 'none';

        var input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'updates[]';
        input.value = '';
        form.appendChild(input);

        var currencyInput = document.createElement('input');
        currencyInput.type = 'hidden';
        currencyInput.name = 'currency';
        currencyInput.value = currency;
        form.appendChild(currencyInput);

        document.body.appendChild(form);
        form.submit();
      }

      closeList();
    });

    // Close when clicking outside
    document.addEventListener('click', function (e) {
      if (!switcher.contains(e.target)) {
        closeList();
      }
    });

    // Keyboard navigation within list
    list.addEventListener('keydown', function (e) {
      var options = Array.from(list.querySelectorAll('.rtl-currency-switcher__option-btn'));
      var focused = document.activeElement;
      var idx = options.indexOf(focused);

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        var next = options[(idx + 1) % options.length];
        if (next) next.focus();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        var prev = options[(idx - 1 + options.length) % options.length];
        if (prev) prev.focus();
      } else if (e.key === 'Escape') {
        closeList();
        trigger.focus();
      }
    });
  }

  document.querySelectorAll('.rtl-currency-switcher').forEach(initSwitcher);
})();
</script>

{% schema %}
{
  "name": "Currency Switcher",
  "target": "section",
  "settings": [
    {
      "type": "select",
      "id": "position",
      "label": "Position",
      "options": [
        { "value": "header", "label": "Header" },
        { "value": "footer", "label": "Footer" },
        { "value": "inline", "label": "Inline" }
      ],
      "default": "header"
    },
    {
      "type": "checkbox",
      "id": "show_symbol",
      "label": "Show currency symbol",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_currency_name",
      "label": "Show currency name",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show currency icon",
      "default": true
    }
  ]
}
{% endschema %}
