{% comment %}
  RTL Checkout Support
  Injects RTL styles when the store locale is Arabic, Hebrew, or Farsi.
{% endcomment %}

{% assign rtl_locales = "ar,he,fa" | split: "," %}
{% assign is_rtl = false %}

{% for locale in rtl_locales %}
  {% if request.locale.iso_code == locale %}
    {% assign is_rtl = true %}
    {% break %}
  {% endif %}
{% endfor %}

{% if is_rtl %}
<style>
  /* RTL Direction */
  html,
  body,
  .checkout,
  [data-checkout] {
    direction: rtl;
    text-align: right;
  }

  /* Arabic/RTL Font Stack */
  body,
  input,
  select,
  textarea,
  button {
    font-family: "Noto Sans Arabic", "Noto Sans Hebrew", "Segoe UI", Tahoma, Arial, sans-serif;
  }

  /* Flip form layouts */
  .field__label {
    text-align: right;
  }

  .field__input {
    text-align: right;
  }

  /* Flip flex containers */
  .content-box__row,
  .review-block__content,
  .order-summary__section {
    direction: rtl;
  }

  /* Flip breadcrumbs and navigation */
  .breadcrumb,
  .step__footer {
    direction: rtl;
  }

  /* Ensure price and currency display correctly */
  .payment-due__price,
  .order-summary__emphasis,
  .total-line__price {
    direction: ltr;
    unicode-bidi: embed;
  }

  /* Flip padding/margin for common checkout elements */
  .radio-wrapper {
    padding-left: 0;
    padding-right: 1.75em;
  }

  .radio-wrapper::before,
  .radio-wrapper .input-radio {
    left: auto;
    right: 0;
  }

  /* Flip checkbox alignment */
  .input-checkbox {
    margin-left: 0.75em;
    margin-right: 0;
  }

  /* Ensure logos and icons maintain correct orientation */
  .logo {
    text-align: right;
  }
</style>
{% endif %}
