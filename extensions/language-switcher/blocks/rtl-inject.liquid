{% comment %}
  RTL Storefront — Automatic RTL Injection
  Detects RTL locales and injects direction, fonts, and CSS.
{% endcomment %}

{% assign locale_code = request.locale.iso_code | split: '-' | first %}
{% assign is_rtl = false %}
{% if locale_code == 'ar' or locale_code == 'he' or locale_code == 'fa' or locale_code == 'ur' %}
  {% assign is_rtl = true %}
{% endif %}

{% if is_rtl %}
<style>
  /* RTL Direction */
  html { direction: rtl; }
  body { text-align: right; direction: rtl; }

  /* RTL Font Stack */
  {% if locale_code == 'ar' %}
    body { font-family: '{{ block.settings.arabic_font | default: "Noto Sans Arabic" }}', 'Cairo', system-ui, sans-serif; }
  {% elsif locale_code == 'he' %}
    body { font-family: '{{ block.settings.hebrew_font | default: "Heebo" }}', 'Rubik', system-ui, sans-serif; }
  {% elsif locale_code == 'fa' %}
    body { font-family: 'Vazirmatn', 'Noto Sans Arabic', system-ui, sans-serif; }
  {% endif %}

  /* Flex/Grid RTL */
  .grid, [class*="grid"] { direction: rtl; }

  /* Logical properties fallback */
  .ml-auto, [class*="ml-auto"] { margin-left: unset !important; margin-right: auto !important; }
  .mr-auto, [class*="mr-auto"] { margin-right: unset !important; margin-left: auto !important; }
  .text-left { text-align: right !important; }
  .text-right { text-align: left !important; }

  /* Navigation */
  .header__menu-item svg { transform: scaleX(-1); }

  /* Product gallery thumbnails */
  .product__media-list { direction: rtl; }

  /* Cart drawer */
  .cart-drawer, .drawer { left: 0; right: auto; transform: translateX(-100%); }
  .cart-drawer.active, .drawer.is-open { transform: translateX(0); }

  /* Form elements */
  input, textarea, select { text-align: right; direction: rtl; }
  input[type="email"], input[type="url"], input[type="tel"] { direction: ltr; text-align: left; }

  /* Preserve LTR for numbers and prices */
  .price, .money, [class*="price"], [data-price] { direction: ltr; unicode-bidi: isolate; }

  /* Breadcrumbs */
  .breadcrumbs__separator, .breadcrumb-separator { transform: scaleX(-1); }

  /* Pagination */
  .pagination__arrow--prev svg { transform: rotate(180deg); }
  .pagination__arrow--next svg { transform: rotate(180deg); }
</style>

{% if block.settings.load_google_fonts %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
{% if locale_code == 'ar' %}
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Arabic:wght@400;500;600;700&family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">
{% elsif locale_code == 'he' %}
<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;600;700&family=Rubik:wght@400;500;600;700&display=swap" rel="stylesheet">
{% elsif locale_code == 'fa' %}
<link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@400;500;600;700&display=swap" rel="stylesheet">
{% endif %}
{% endif %}

{% else %}
  {%- comment -%} LTR — no injection needed {%- endcomment -%}
{% endif %}

{% schema %}
{
  "name": "RTL Auto-Inject",
  "target": "head",
  "settings": [
    { "type": "checkbox", "id": "load_google_fonts", "label": "Load Google Fonts for RTL", "default": true },
    { "type": "text", "id": "arabic_font", "label": "Arabic font family", "default": "Noto Sans Arabic" },
    { "type": "text", "id": "hebrew_font", "label": "Hebrew font family", "default": "Heebo" }
  ]
}
{% endschema %}
