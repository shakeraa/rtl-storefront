{% comment %} MENA Payment Methods Badge Block {% endcomment %}

<style>
.rtl-mena-payments { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; justify-content: {{ block.settings.alignment }}; padding: 1rem 0; }
.rtl-mena-payments__badge { display: inline-flex; align-items: center; gap: 0.25rem; padding: 0.25rem 0.75rem; border: 1px solid var(--color-border, #e5e5e5); border-radius: 4px; font-size: 0.75rem; background: var(--color-background, #fff); }
.rtl-mena-payments__badge svg { width: 20px; height: 20px; }
.rtl-mena-payments__label { font-size: 0.7rem; color: var(--color-foreground-subdued, #666); margin-bottom: 0.25rem; }
[dir="rtl"] .rtl-mena-payments { direction: rtl; }
</style>

{% if block.settings.show_label %}
  <p class="rtl-mena-payments__label">{{ block.settings.label }}</p>
{% endif %}

<div class="rtl-mena-payments">
  {% if block.settings.show_tamara %}
    <div class="rtl-mena-payments__badge">
      <span>تمارا</span>
      <span>Tamara</span>
    </div>
  {% endif %}

  {% if block.settings.show_tabby %}
    <div class="rtl-mena-payments__badge">
      <span>تابي</span>
      <span>Tabby</span>
    </div>
  {% endif %}

  {% if block.settings.show_mada %}
    <div class="rtl-mena-payments__badge">
      <span>مدى</span>
      <span>mada</span>
    </div>
  {% endif %}

  {% if block.settings.show_stcpay %}
    <div class="rtl-mena-payments__badge">
      <span>STC Pay</span>
    </div>
  {% endif %}

  {% if block.settings.show_applepay %}
    <div class="rtl-mena-payments__badge">
      <span>Apple Pay</span>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "MENA Payments",
  "target": "section",
  "settings": [
    { "type": "checkbox", "id": "show_label", "label": "Show label", "default": true },
    { "type": "text", "id": "label", "label": "Label text", "default": "We accept" },
    { "type": "select", "id": "alignment", "label": "Alignment", "options": [
      { "value": "flex-start", "label": "Left" },
      { "value": "center", "label": "Center" },
      { "value": "flex-end", "label": "Right" }
    ], "default": "center" },
    { "type": "checkbox", "id": "show_tamara", "label": "Show Tamara", "default": true },
    { "type": "checkbox", "id": "show_tabby", "label": "Show Tabby", "default": true },
    { "type": "checkbox", "id": "show_mada", "label": "Show mada", "default": true },
    { "type": "checkbox", "id": "show_stcpay", "label": "Show STC Pay", "default": true },
    { "type": "checkbox", "id": "show_applepay", "label": "Show Apple Pay", "default": false }
  ]
}
{% endschema %}
